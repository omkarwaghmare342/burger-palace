# Fast2SMS Configuration
# Get your API key from: https://www.fast2sms.com/dashboard/profile
REACT_APP_FAST2SMS_API_KEY=your_fast2sms_api_key_here

# Razorpay Configuration (Optional - for payments)
# Get these from your Razorpay Dashboard: https://dashboard.razorpay.com/app/keys
REACT_APP_RAZORPAY_KEY_ID=your_razorpay_key_id_here
REACT_APP_RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
